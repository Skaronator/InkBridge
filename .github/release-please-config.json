{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-v-in-tag": false,
  "include-v-in-release-name": false,
  "pull-request-title-pattern": "chore(release): release ${version}",
  "pull-request-header": ":robot: I have created a release",
  "label": "release",
  "changelog-type": "default",
  "packages": {
    ".": {
      "release-type": "go",
      "changelog-path": "inkbridge/CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "inkbridge/config.yaml",
          "jsonpath": "$.version"
        }
      ],
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "perf", "section": "Performance Improvements" },
        { "type": "revert", "section": "Reverts" },
        { "type": "docs", "section": "Documentation" },
        { "type": "misc", "section": "Miscellaneous" },
        { "type": "chore", "section": "Chores" },
        { "type": "style", "section": "Styles" },
        { "type": "refactor", "section": "Code Refactoring" },
        { "type": "test", "section": "Tests" },
        { "type": "build", "section": "Build System" },
        { "type": "ci", "section": "Continuous Integration" }
      ]
    }
  }
}
